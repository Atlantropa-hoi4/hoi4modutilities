{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "out",
    "rootDir": ".",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node",
      "mocha",
      "vscode"
    ],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noFallthroughCasesInSwitch": true,
    "importHelpers": true
  },
  "include": [
    "src/**/*.ts",
    "webviewsrc/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "dist",
    "out",
    "static",
    "scripts"
  ]
}
